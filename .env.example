# Backend REST API base URL (client + server)
NUXT_PUBLIC_APP_URL=https://api.example.com

# Auth service base URL (client + server; falls back to NUXT_PUBLIC_APP_URL if unset)
NUXT_PUBLIC_AUTH_URL=https://auth.example.com

# S3-compatible static asset base URL (client + server)
NUXT_PUBLIC_STORAGE_URL=https://cdn.example.com

# AES-GCM symmetric key for encrypting sensitive query params (server-only)
# Must be a high-entropy random string — NOT a human password
NUXT_CRYPTO_SECRET=change-this-to-a-random-64-char-hex-string

# Canonical site URL used in og:url / sitemaps
NUXT_PUBLIC_SITE_URL=https://zeemic.com
